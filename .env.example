# Meeting AI ↔ Anna integration — environment
# Copy to .env (or just export these) and the tools pick them up.

# Which AI backend to use: anna | byok   (default: byok)
AI_PROVIDER=anna

# ── Anna Platform (hosted LLM / Sampling API) ────────────────────────────────
# Set these to route reasoning through Anna with NO personal key.
# Defaults assume an OpenAI-compatible POST {ANNA_API_URL}/chat/completions.
# If Anna's Sampling API differs, adjust src/llm.mjs (chatComplete).
ANNA_API_URL=
ANNA_API_TOKEN=
ANNA_MODEL=anna-default

# ── BYOK (your own key) — used when AI_PROVIDER=byok ─────────────────────────
# Any OpenAI-compatible endpoint. OPENAI_API_KEY is also accepted.
BYOK_API_URL=https://api.openai.com/v1
BYOK_API_KEY=
BYOK_MODEL=gpt-4o-mini

# Force the deterministic local mock (no network) — great for a guaranteed demo.
# MOCK=1
