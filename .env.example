# Meeting AI ↔ Anna integration — environment
# Copy to .env (or just export these).

# Which AI backend to use: anna | byok   (default: byok)
AI_PROVIDER=anna

# ── Anna ─────────────────────────────────────────────────────────────────────
# Anna mode uses the Anna App Runtime (anna.llm.complete) — NO env vars and NO
# personal key. It works automatically when the page runs inside an Anna app;
# the model, quota and billing stay on the Anna Host. Outside an Anna app (e.g.
# the Node CLI) Anna mode falls back to mock.

# ── BYOK (your own key) — used when AI_PROVIDER=byok ─────────────────────────
# Any OpenAI-compatible endpoint. OPENAI_API_KEY is also accepted.
BYOK_API_URL=https://api.openai.com/v1
BYOK_API_KEY=
BYOK_MODEL=gpt-4o-mini

# Force the deterministic local mock (no network) — great for a guaranteed demo.
# MOCK=1
