{
  "name": "meeting-ai-anna",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Anna Platform integration for Meeting AI — Executa tools for question detection, answer generation, and meeting summaries.",
  "engines": { "node": ">=18" },
  "scripts": {
    "describe": "node cli.mjs --describe",
    "executa": "node cli.mjs",
    "detect": "node cli.mjs --invoke detect_question --args",
    "answer": "node cli.mjs --invoke answer_question --args",
    "summarize": "node cli.mjs --invoke summarize_meeting --args",
    "demo": "node demo/run-demo.mjs"
  }
}
